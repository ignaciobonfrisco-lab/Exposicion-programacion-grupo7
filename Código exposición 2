public class UsuarioSistema {

    String nombre;
    String email;
    String rol;

    // Constructor por defecto
    public UsuarioSistema() {
        this.nombre = "Invitado";
        this.email = "sin@email.com";
        this.rol = "Postulante";
    }

    // Constructor con algunos parámetros
    public UsuarioSistema(String nombre, String email) {
        this.nombre = nombre;
        this.email = email;
        this.rol = "LECTOR";
    }

    //  Constructor completo
    public UsuarioSistema(String nombre, String email, String rol) {
        this.nombre = nombre;
        this.email = email;
        this.rol = rol;
    }

    // Método para mostrar datos
    public void mostrarUsuario() {
        System.out.println("Nombre: " + nombre +
                " | Email: " + email +
                " | Rol: " + rol);
    }
    public static void main(String[] args) {

        UsuarioSistema u1 = new UsuarioSistema();
        UsuarioSistema u2 = new UsuarioSistema("Juan", "juan@gmail.com");
        UsuarioSistema u3 = new UsuarioSistema("Ana", "ana@gmail.com", "ADMIN");

        u1.mostrarUsuario();
        u2.mostrarUsuario();
        u3.mostrarUsuario();
    }
}
